{
  "name": "controle-frotas",
  "version": "1.0.0",
  "description": "API de Controle de Utilização de Automóveis",
  "private": true,
  "engines": {
    "node": "22.13.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --watch src src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "jest --passWithNoTests",
    "test:unit": "jest tests/features --passWithNoTests",
    "test:integration": "jest tests/integration --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "express": "^4.21.0",
    "js-yaml": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
